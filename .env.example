# Database
DATABASE_URL=postgres://cloudify:cloudify@localhost:5432/cloudify

# JWT
JWT_SECRET=change-this-to-a-strong-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=3000

# Redis / Valkey
REDIS_URL=redis://localhost:6379

# Gitea
