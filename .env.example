# Database
DATABASE_URL=postgres://cloudify:cloudify@localhost:5432/cloudify

# JWT
JWT_SECRET=change-this-to-a-strong-random-secret
JWT_EXPIRES_IN_SECONDS=900

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# NATS JetStream
NATS_URL=nats://localhost:4222

# Redis / Valkey
REDIS_URL=redis://localhost:6379

# Gitea / Forgejo
GITEA_URL=http://localhost:3300
GITEA_TOKEN=
GITEA_ORGANIZATION=cloudify

# Vault / OpenBao
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-root-token

# Hypervisor (proxmox | vmware)
HYPERVISOR_PROVIDER=proxmox
PROXMOX_URL=https://pve.example.com:8006
PROXMOX_TOKEN_ID=root@pam!cloudify
PROXMOX_TOKEN_SECRET=

# OpenTofu
TOFU_BINARY_PATH=tofu
TOFU_STATE_BACKEND=pg
